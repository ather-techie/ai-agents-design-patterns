# Copy to `.env` and fill in to run against a live model.
# Without a key (or with USE_MOCK=1), everything runs in deterministic mock mode.

# Your Anthropic API key. Leave unset to stay in offline mock mode.
ANTHROPIC_API_KEY=

# Force offline mock mode even when a key is present (1/true/yes/on).
USE_MOCK=

# Optional overrides:
# AGENT_MODEL=claude-opus-4-8
# AGENT_MAX_STEPS=6
# AGENT_TIMEOUT=60
# AGENT_MAX_TOKENS=1024
# AGENT_LOG=info        # emit structured JSON logs at this level
